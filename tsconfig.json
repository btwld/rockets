    {
      "path": "packages/rockets-access-control"
    },
    {
      "path": "packages/rockets-core"
    },
    {
      "path": "packages/rockets-server"
    },
    {
      "path": "packages/rockets-server-auth"
    },
    {
      "path": "packages/rockets-adapter-firebase"
    },
    {
      "path": "packages/rockets-repository-firestore"
