{
  "moduleFileExtensions": ["js", "json", "ts"],
  "testSequencer": "<rootDir>/scripts/jest-e2e-barrel-last-sequencer.cjs",
  "testEnvironment": "node",
  "testRegex": ".*\\.e2e-spec\\.ts$",
  "testPathIgnorePatterns": ["/node_modules/", "/dist/", "/examples/"],
  "transform": {
    "^.+\\.ts$": ["ts-jest", { "tsconfig": "tsconfig.jest.json" }]
  },
  "maxWorkers": 1,
  "forceExit": true,
  "moduleNameMapper": {
    "^@concepta/nestjs-federated(.*)$": "<rootDir>/packages/rockets-server-auth/src/__fixtures__/stubs/nestjs-federated-stub.ts"
  },
  "setupFiles": [
    "<rootDir>/packages/rockets-server-auth/src/__fixtures__/stubs/patch-concepta-common.ts"
  ],
  "coverageProvider": "v8",
  "collectCoverageFrom": [
    "packages/**/*.ts",
    "!packages/**/*.d.ts",
    "!packages/**/*.interface.ts",
    "!packages/**/*.e2e-spec.ts",
    "!packages/**/*.spec.ts",
    "!packages/**/*.factory.ts",
    "!packages/**/*.seeder.ts",
    "!packages/**/*.seeding.ts",
    "!packages/nestjs-samples/src/**/main.ts",
    "!**/node_modules/**",
    "!**/__mocks__/**",
    "!**/__stubs__/**",
    "!**/__fixtures__/**",
    "!**/dist/**"
  ],
  "coverageDirectory": "coverage-e2e",
  "coverageReporters": ["text", "text-summary", "lcov", "html"]
}
