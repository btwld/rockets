{
  "name": "root",
  "version": "1.0.0-alpha.7",
  "license": "BSD-3-Clause",
  "private": true,
  "workspaces": {
    "packages": [
      "packages/*",
      "!packages/nestjs-access-control",
      "examples/*",
      "examples/sample-code-review",
      "examples/sample-code-review/apps/*",
      "examples/sample-code-review/packages/*"
    ]
  },
  "resolutions": {
    "typeorm": "0.3.28",
