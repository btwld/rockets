{
  "moduleFileExtensions": [
    "js",
    "json",
    "ts"
  ],
  "testEnvironment": "node",
  "roots": [
    "<rootDir>/packages"
  ],
  "testRegex": ".*\\.e2e-spec\\.ts$",
  "testPathIgnorePatterns": [
    "/node_modules/",
    "/dist/",
    "/examples/"
  ],
  "transform": {
    "^.+\\.ts$": [
      "ts-jest",
      {
        "tsconfig": "tsconfig.jest.json"
      }
    ],
    "^.+\\.js$": [
      "babel-jest",
      {
        "configFile": false,
        "plugins": [
          "./scripts/babel-plugin-import-meta-url-filename.cjs",
          "./scripts/babel-plugin-dynamic-import-to-require.cjs",
          "@babel/plugin-transform-modules-commonjs"
        ]
      }
    ]
  },
  "transformIgnorePatterns": [
    "/node_modules/(?!@nestjs/)"
  ],
  "maxWorkers": 1,
  "forceExit": true,
  "moduleNameMapper": {
    "^@concepta/nestjs-invitation/dist/(.*)$": "<rootDir>/node_modules/@concepta/nestjs-invitation/dist/$1"
  }
}
