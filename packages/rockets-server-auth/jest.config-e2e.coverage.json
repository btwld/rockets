{
  "moduleFileExtensions": ["js", "json", "ts"],
  "testEnvironment": "node",
  "testTimeout": 60000,
  "maxWorkers": 2,
  "testRegex": ".*\\.e2e-spec\\.ts$",
  "testPathIgnorePatterns": ["/node_modules/", "/dist/"],
  "transform": {
    "^.+\\.ts$": ["ts-jest", { "tsconfig": "<rootDir>/../../tsconfig.jest.json" }]
  },
  "moduleNameMapper": {
    "^@concepta/nestjs-core/aggregate$": "<rootDir>/../../node_modules/@concepta/nestjs-core/dist/index-aggregate",
    "^@concepta/nestjs-invitation/dist/(.*)$": "<rootDir>/../../node_modules/@concepta/nestjs-invitation/dist/$1"
  },
  "coverageProvider": "v8",
  "collectCoverageFrom": [
    "src/**/*.ts",
    "!src/**/*.d.ts",
    "!src/**/*.interface.ts",
    "!src/**/*.e2e-spec.ts",
    "!src/**/*.spec.ts",
    "!src/**/__fixtures__/**",
    "!src/**/__tests__/**",
    "!src/**/__e2e__/**"
  ],
  "coverageDirectory": "coverage-e2e",
  "coverageReporters": ["text", "text-summary", "lcov", "html"]
}
