{
  "moduleFileExtensions": ["js", "json", "ts"],
  "testEnvironment": "node",
  "testTimeout": 60000,
  "maxWorkers": 2,
  "testRegex": ".*\\.e2e-spec\\.ts$",
  "testPathIgnorePatterns": ["/node_modules/", "/dist/"],
  "transform": {
    "^.+\\.ts$": ["ts-jest", { "tsconfig": "<rootDir>/../../tsconfig.jest.json" }]
  },
  "moduleNameMapper": {
    "^@concepta/nestjs-common/aggregate$": "<rootDir>/../../node_modules/@concepta/nestjs-common/dist/index-aggregate",
    "^@concepta/nestjs-federated(.*)$": "<rootDir>/src/__fixtures__/stubs/nestjs-federated-stub.ts"
  },
  "setupFiles": [
    "<rootDir>/src/__fixtures__/stubs/patch-concepta-common.ts"
  ],
  "coverageProvider": "v8",
  "collectCoverageFrom": [
    "src/**/*.ts",
    "!src/**/*.d.ts",
    "!src/**/*.interface.ts",
    "!src/**/*.e2e-spec.ts",
    "!src/**/*.spec.ts",
    "!src/**/__fixtures__/**",
    "!src/**/__tests__/**",
    "!src/**/__e2e__/**"
  ],
  "coverageDirectory": "coverage-e2e",
  "coverageReporters": ["text", "text-summary", "lcov", "html"]
}
