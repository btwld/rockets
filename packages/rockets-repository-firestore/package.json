{
  "name": "@bitwild/rockets-repository-firestore",
  "version": "1.0.0-alpha.0",
  "description": "Firestore repository adapter for Rockets — implements RepositoryModuleInterface and RepositoryAdapter from @concepta/nestjs-repository",
  "author": "Thiago Ramalho <thiago.ramalho@concepta.com>",
  "license": "BSD-3-Clause",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/btwld/rockets.git",
    "directory": "packages/rockets-repository-firestore"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "files": [
    "dist/**/!(*.spec|*.e2e-spec|*.fixture).{js,d.ts}",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:watch": "tsc -p tsconfig.json --watch",
    "test": "cd ../.. && jest --testPathPattern=rockets-repository-firestore"
  },
  "dependencies": {
    "@bitwild/rockets-core": "workspace:^",
    "@concepta/nestjs-core": "8.0.0-alpha.7",
    "@concepta/nestjs-repository": "8.0.0-alpha.7"
  },
  "devDependencies": {
    "@nestjs/common": "11.1.18",
    "@nestjs/testing": "11.1.18",
    "firebase-admin": "^13.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "typescript": "^5.4.0"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.0.0",
    "firebase-admin": ">=11.0.0",
    "reflect-metadata": "^0.1.13 || ^0.2.0"
  },
  "peerDependenciesMeta": {
    "firebase-admin": {
      "optional": true
    }
  }
}
