{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "strictPropertyInitialization": false,
    "typeRoots": [
      "./node_modules/@types",
      "../../node_modules/@types"
    ]
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/**/*.spec.ts",
    "src/**/*.typetest.ts",
    "src/**/*.e2e-spec.ts",
    "src/**/__tests__/**",
    "src/**/__fixtures__/**",
    "src/**/__e2e__/**"
  ],
  "references": [
    { "path": "../rockets-core" }
  ]
}
