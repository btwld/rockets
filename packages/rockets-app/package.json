{
  "name": "@bitwild/rockets-app",
  "version": "0.0.1-alpha.0",
  "description": "Rockets App - Core framework module for Rockets applications",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./aggregate": {
      "types": "./dist/index-aggregate.d.ts",
      "default": "./dist/index-aggregate.js"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "default": "./dist/testing.js"
    }
  },
  "license": "BSD-3-Clause",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/**/!(*.spec|*.e2e-spec|*.fixture|*.mock).{js,d.ts}",
    "!dist/**/__tests__/**",
    "!dist/**/__fixtures__/**"
  ],
  "dependencies": {
    "@nestjs/common": "^11.1.9",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.9",
    "@nestjs/swagger": "^11.2.2",
    "ms": "^2.1.3",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.9",
    "@types/supertest": "^6.0.3",
    "jest-mock-extended": "^4.0.0",
    "supertest": "^6.3.4"
  },
  "peerDependencies": {
    "@nestjs/cqrs": "^11.0.0",
    "class-transformer": "*",
    "class-validator": "*",
    "rxjs": "^7.8.1"
  },
  "peerDependenciesMeta": {
    "@nestjs/cqrs": {
      "optional": true
    }
  }
}
