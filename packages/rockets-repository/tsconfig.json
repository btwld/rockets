{
  "extends": "../../tsconfig",
  "compilerOptions": {
    "composite": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "typeRoots": [
      "./node_modules/@types",
      "../../node_modules/@types"
    ]
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "node_modules",
    "dist",
    "src/**/*.spec.ts",
    "src/**/*.e2e-spec.ts",
    "src/**/__tests__/**",
    "src/**/__fixtures__/**",
    "src/**/__e2e__/**"
  ]
}
