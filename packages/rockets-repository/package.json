{
  "name": "@bitwild/rockets-repository",
  "version": "0.0.1-alpha.0",
  "description": "Rockets NestJS Repository",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "default": "./dist/testing.js"
    }
  },
  "license": "BSD-3-Clause",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/**/!(*.spec|*.e2e-spec|*.fixture|*.mock).{js,d.ts}",
    "!dist/**/__tests__/**",
    "!dist/**/__fixtures__/**"
  ],
  "dependencies": {
    "@bitwild/rockets-app": "workspace:^",
    "@nestjs/common": "^11.1.9",
    "@nestjs/core": "^11.1.9",
    "@tsyche/membrane": "^0.7.0"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.9",
    "jest-mock-extended": "^4.0.0"
  },
  "peerDependencies": {
    "class-transformer": "*",
    "class-validator": "*",
    "rxjs": "^7.8.1"
  }
}
