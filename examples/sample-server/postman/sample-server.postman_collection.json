            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Rex\",\n  \"species\": \"dog\",\n  \"breed\": \"labrador\",\n  \"age\": 3,\n  \"color\": \"black\",\n  \"description\": \"Friendly large dog\",\n  \"status\": \"active\",\n  \"uniqueRef\": \"rex-{{$timestamp}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/pets",
              "host": ["{{baseUrl}}"],
              "path": ["pets"]
            },
            "description": "`uniqueRef` is optional but enforced unique by the pet create handler — duplicates are rejected on create. The body uses `{{$timestamp}}` so re-running the request always produces a fresh value."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const r = pm.response.json();",
                  "if (r.id) pm.collectionVariables.set('petId', r.id);",
                  "if (r.uniqueRef) pm.collectionVariables.set('petUniqueRef', r.uniqueRef);",
                  "pm.test('returns id', () => pm.expect(r).to.have.property('id'));"
                ]
              }
            }
          ]
        },
