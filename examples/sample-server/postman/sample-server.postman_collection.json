{
  "info": {
    "name": "Rockets — Sample Server",
    "_postman_id": "8a4f6c2e-4b1a-4f1a-9c2e-001000010001",
    "description": "End-to-end collection for `examples/sample-server`. Auth/me + CRUD for pets, tags, pet-tags (sub), pet-vaccinations, appointments, reminders, plus pet-share / pet-transfer / admin audit-logs.\n\n**Variables auto-populated:**\n- `accessToken` — set by `POST /auth/signup` and `POST /auth/login`.\n- `userId` — set by `POST /auth/signup` / `GET /me`.\n- `petId`, `tagId`, `petTagId`, `vaccinationId`, `appointmentId`, `reminderId` — set by their respective `POST` requests.\n\nRun the requests in order the first time (signup → create-pet → create-tag → attach-tag) so each ID feeds the next.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.collectionVariables.get('baseUrl')) {",
          "  pm.collectionVariables.set('baseUrl', 'http://localhost:3000');",
          "}",
          "// Surface the current accessToken on every request so DevTools console",
          "// shows whether the Authorization header is built from a stale or empty value.",
          "const tok = pm.collectionVariables.get('accessToken') || '';",
          "if (tok) {",
          "  console.log('→ accessToken (first 30):', tok.substring(0, 30) + '...');",
          "} else {",
          "  console.warn('→ accessToken is EMPTY — protected routes will 401. Run signup or login first.');",
          "}"
        ]
      }
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000", "type": "string" },
    { "key": "accessToken", "value": "", "type": "string" },
    { "key": "userId", "value": "", "type": "string" },
    { "key": "petId", "value": "", "type": "string" },
    { "key": "petUniqueRef", "value": "", "type": "string" },
    { "key": "petTagId", "value": "", "type": "string" },
    { "key": "tagId", "value": "", "type": "string" },
    { "key": "vaccinationId", "value": "", "type": "string" },
    { "key": "appointmentId", "value": "", "type": "string" },
    { "key": "reminderId", "value": "", "type": "string" },
    { "key": "shareUserId", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST /auth/signup",
          "request": {
            "method": "POST",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"alice@example.com\",\n  \"password\": \"hunter2\",\n  \"name\": \"Alice\",\n  \"role\": \"user\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/signup",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "signup"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const r = pm.response.json();",
                  "console.log('signup status:', pm.response.code);",
                  "console.log('signup body:', JSON.stringify(r, null, 2));",
                  "if (r && r.accessToken) {",
                  "  pm.collectionVariables.set('accessToken', r.accessToken);",
                  "  if (pm.environment && pm.environment.name) pm.environment.set('accessToken', r.accessToken);",
                  "  console.log('✓ accessToken stored:', String(r.accessToken).substring(0, 30) + '...');",
                  "} else {",
                  "  console.error('✗ no accessToken in response — variable NOT updated');",
                  "}",
                  "if (r && r.id) {",
                  "  pm.collectionVariables.set('userId', r.id);",
                  "  console.log('✓ userId stored:', r.id);",
                  "}",
                  "pm.test('signup returns accessToken', () => pm.expect(r).to.have.property('accessToken'));",
                  "pm.test('accessToken is non-empty after signup', () => pm.expect(pm.collectionVariables.get('accessToken')).to.be.a('string').that.is.not.empty);"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /auth/login",
          "request": {
            "method": "POST",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"alice@example.com\",\n  \"password\": \"hunter2\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const r = pm.response.json();",
                  "console.log('login status:', pm.response.code);",
                  "console.log('login body:', JSON.stringify(r, null, 2));",
                  "if (r && r.accessToken) {",
                  "  pm.collectionVariables.set('accessToken', r.accessToken);",
                  "  if (pm.environment && pm.environment.name) pm.environment.set('accessToken', r.accessToken);",
                  "  console.log('✓ accessToken stored:', String(r.accessToken).substring(0, 30) + '...');",
                  "} else {",
                  "  console.error('✗ no accessToken in response — variable NOT updated');",
                  "}",
                  "pm.test('login returns accessToken', () => pm.expect(r).to.have.property('accessToken'));"
                ]
              }
            }
          ]
        }
      ]
    },
