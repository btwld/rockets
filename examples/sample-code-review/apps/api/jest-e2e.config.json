{
  "moduleFileExtensions": ["js", "json", "ts"],
  "testEnvironment": "node",
  "testRegex": ".*\\.e2e-spec\\.ts$",
  "testPathIgnorePatterns": ["/node_modules/", "/dist/"],
  "roots": ["<rootDir>/test"],
  "testTimeout": 30000,
  "maxWorkers": 1,
  "transform": {
    "^.+\\.ts$": ["ts-jest", { "tsconfig": "<rootDir>/tsconfig.json" }]
  },
  "moduleNameMapper": {
    "^../repository/code-review-reports\\.persistence$": "<rootDir>/test/stubs/code-review-reports.persistence.stub.ts"
  }
}
