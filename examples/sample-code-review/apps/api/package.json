{
  "name": "api",
  "private": true,
  "version": "0.0.0",
  "description": "sample-code-review API — NestJS + Rockets (Firebase auth, GitHub OAuth, code review).",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "nest start --watch",
    "start": "nest start",
    "type-check": "tsc --noEmit -p tsconfig.json",
    "lint": "echo \"lint: configure eslint when needed\"",
    "clean": "rm -rf dist",
    "test:e2e": "jest --config jest-e2e.config.json",
    "test:e2e:auth": "jest --config jest-e2e.config.json --testPathPattern=auth-connection"
  },
  "dependencies": {
    "@bitwild/rockets": "workspace:^",
    "@bitwild/rockets-adapter-firebase": "workspace:^",
    "@bitwild/rockets-core": "workspace:^",
    "@bitwild/rockets-repository-firestore": "workspace:^",
    "@bitwild/rockets-repository-typeorm": "workspace:^",
    "@concepta/nestjs-core": "8.0.0-alpha.7",
    "@concepta/nestjs-repository": "8.0.0-alpha.7",
    "@nestjs/common": "11.1.18",
    "@nestjs/config": "4.0.0",
    "@nestjs/core": "11.1.18",
    "@nestjs/cqrs": "11.0.3",
    "@nestjs/platform-express": "11.1.18",
    "@nestjs/swagger": "11.2.5",
    "@nestjs/typeorm": "11.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "firebase-admin": "^13.0.0",
    "helmet": "^8.0.0",
    "reflect-metadata": "^0.1.14",
    "rxjs": "^7.8.1",
    "sqlite3": "^5.1.7",
    "typeorm": "^0.3.20",
    "zod": "^4.1.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/testing": "11.1.18",
    "@types/jest": "^29.5.0",
    "@types/node": "^18.19.44",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.4",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  },
  "resolutions": {
    "@nestjs/common": "11.1.18",
    "@nestjs/core": "11.1.18",
    "@nestjs/platform-express": "11.1.18"
  }
}
